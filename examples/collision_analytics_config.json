  "profiles": [
    {
      "name": "Fatal + Injury Last 5 Years",
      "description": "Severe collisions in recent period",
      "filters": {
        "date_enabled": true,
        "date_start": "2020-01-01",
        "date_end": "2024-12-31",
        "selection_only": true,
        "categories": {
          "accident_class": ["1", "2"]
        }
      }
    },
    {
      "name": "Signalized Intersections",
      "description": "Collisions at signalized intersections",
      "filters": {
        "date_enabled": false,
        "selection_only": true,
        "categories": {
          "traffic_control": ["1"]
        }
      }
    },
    {
      "name": "Active School Zones",
      "description": "Collisions near schools with school guard or bus present",
      "filters": {
        "date_enabled": false,
        "selection_only": true,
        "categories": {
          "traffic_control": ["6", "7"]
        }
      }
    }
  ],
  "ui_preferences": {
    "top_n_default": 15,
    "chart_height": 420,
    "show_value_labels": true,
    "default_date_range_years": 10
